<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>4.0.4</version>
    <relativePath/>
  </parent>

  <groupId>com.temporalrift</groupId>
  <artifactId>temporal-rift-build-tools</artifactId>
  <version>1.0.1</version>
  <packaging>jar</packaging>

  <name>Temporal Rift Build Tools</name>
  <description>Build configuration resources — Checkstyle rules for Temporal Rift services</description>

  <properties>
    <!-- Skip code quality plugins — this module only contains resources, not Java sources -->
    <spotless.skip>true</spotless.skip>
    <checkstyle.skip>true</checkstyle.skip>
    <enforcer.skip>true</enforcer.skip>
  </properties>

  <profiles>
    <!-- add ghrepo profile so deploys can use the unified server id 'github' in settings.xml -->
    <profile>
      <id>ghrepo</id>
      <distributionManagement>
        <repository>
          <id>github</id>
          <name>Temporal Rift GitHub Packages</name>
          <url>https://maven.pkg.github.com/temporal-rift/temporal-rift-bom</url>
        </repository>
      </distributionManagement>
    </profile>
  </profiles>

</project>
